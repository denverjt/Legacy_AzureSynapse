{
  "name": "OUT_M3_JSONSource",
  "properties": {
    "annotations": [],
    "linkedServiceName": {
      "referenceName": "tlcdw-WorkspaceDefaultStorage",
      "type": "LinkedServiceReference"
    },
    "parameters": {
      "M3FileName": {
        "type": "string"
      }
    },
    "type": "Binary",
    "typeProperties": {
      "location": {
        "fileSystem": "tlclakefs",
        "folderPath": {
          "type": "Expression",
          "value": "@concat('M3/JSONProcess/', dataset().M3FileName)"
        },
        "type": "AzureBlobFSLocation"
      }
    }
  }
}
