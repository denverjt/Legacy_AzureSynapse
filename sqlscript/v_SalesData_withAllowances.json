			"query": "CREATE VIEW v_SalesData_withAllowances\nAS\n-- drop view v_SalesData_withAllowances\nSELECT      *, CASE WHEN [Invoice ID] IN ('2400163926','2400120688',\n'2400088773','2999906670','2400106134','2400104902','2400104904','2400088775','2400088773','2400088775',\n'2400070870','2400088775','2400115885','2400224642','2400102150','2400099072','2400088775',\n'2400081300','2400081300','2400069177','2400102150','2400088773','2999910798','2400088773','2400088771',\n'2400088771','2999910749','2400064286','2400078973','2400074626','2400069177','2400088773','2400069177',\n'2999900069','2400062143','2400078971','2400088771','2400069177','2400088771','2400088775','2400102150',\n'2400069177','2400088771','2400084386','2400088771','2400084386','2400084386','2400088771','2400081300',\n'2999909021','2999909022','2400084386','2400088771','2400069177','2400069177','2400084386','2400150654',\n'2400102150','2400069177','2400088771','2400220700','2400102152','2400083567','2999906174','2400069177',\n'2400069177','2999910910','2400084386','2400065693','2400089787','2400083567','2400089787','2400104826',\n'2400069177','2400109773','2400069177','2400233640','2400084386','2400069177','2400154812','2400124016',\n'2999914032','2400127031','2400069177','2999911965','2400088775','2400088773','2999906172','2999915479',\n'2999911652','2999907224','2999909808','2400111034','2999909890','2400154812','2400069177','2400154812',\n'2400063890','2400154812','2400154812','2999916179','2999911042','2999910087','2999910911','2400069177',\n'2999910566','2400178310','2400178310','2400178312','2400102165','2400134396','2400069177','2999906173',\n'2999912233','2999915628','2400070220','2999909353','2999906378','2400124016','2400124016','2999910515',\n'2999910515','2400111032','2999909506','2400074626','2400065695','2999908062','2999909124','2400069177',\n'2999916179','2400097244','2400069177','2999909607','2999915737','2999909918','2999912234','2999910515',\n'2400069177','2999909353','2999911569','2400069177','2999915841','2400083553','2400083553','2400083567',\n'2400069177','2400083567','2999915641','2400148778','2999916047','2400124016','2400148778','2400178314',\n'2400178312','2400069177','2400069177','2999913883','2999911042','2400154812','2400069177','2999911539',\n'2999910515','2999912951','2400124016','2400124016','2400148778','2999910515','2400069177','2999908682',\n'2999900259','2999910515','2400148778','2999910516','2400148778','2999911778','2999910909','2999915840',\n'2999916148','2400100727','2400100727','2400148778','2999906672','2400091394','2999910515','2400178310',\n'2400178314','2400178310','2400178310','2400178310','2400178314','2400178310','2400178310','2400178312',\n'2400178310','2400178310','2400178310','2400148778','2400148778','2999916179','2999915737','2400091394',\n'2400148778','2999910514','2999910515','2999906278','2999915508','2999910516','2400124016','2999900106',\n'2999913877','2999910515','2999910515','2999910515','2999910515','2999910515','2400148778','2999910316',\n'2999900106','2999910515','2999906424','2999906425','2999913877','2999916179','2400148778','2400078973',\n'2400078973','2400124016','2400148778','2400078973','2400078973','2400124016','2400078973','2400078973',\n'2400078973','2400078973','2400148778','2400148778','2400148778','2400078971','2400071554','2999916179',\n'2400124016','2400124016','2999910516','2400148778','2400148778','2400148778','2400109782','2400078973',\n'2400078973','2400148778','2400148778','2400148778','2400148778','2400148778','2400148778','2400148778',\n'2400148778','2400148778','2999916179','2400109771','2999908401','2400148778','2400124016','2400124016',\n'2400148778','2400148778','2400070870','2400148778','2400148778','2400148778','2999900106','2999911039',\n'2999911039')then 'Sales' when [Sales Qty] < 0 or [Sales Amt] < 0 then 'Returns' else 'Sales' end as [Sales Type]\nFROM        \n(\nSELECT     ODH.CUNO COLLATE SQL_Latin1_General_CP1_CS_AS AS [Customer ID]\n,          OC.CUNM COLLATE SQL_Latin1_General_CP1_CS_AS AS [Customer Name]\n,          OL.CUOR COLLATE SQL_Latin1_General_CP1_CS_AS AS [Customer PO]\n,          OL.ORNO AS [Order ID]\n,          OH.ORDT as [Order Date]\n,          LE.CINO COLLATE SQL_Latin1_General_CP1_CS_AS AS [Invoice ID]\n,          OL.WHLO as Warehouse\n,          LE.ACDT  as [Date]\n,           OL.PONR as [Line Number]\n,          IM.ITNO COLLATE SQL_Latin1_General_CP1_CS_AS as [Item Number]\n,          CASE WHEN MP.STRT = 'KIT' AND ODL.POSX = 0 THEN 0\n           WHEN LE.CUAM = 0 THEN 0 else  OL.NEPR END as [Unit Price]\n,          CASE WHEN MP.STRT = 'KIT' AND ODL.POSX = 0 THEN 0\n            WHEN OH.ORTP IN ('E80', 'E90') and OL.SAPR*ODL.IVQT*LE.ARAT > 0 then OL.SAPR*ODL.IVQT*LE.ARAT*-1\n            WHEN LE.CUAM = 0 THEN 0 \n            WHEN LE.CINO = '2999910570' then 451*ODL.IVQT else  OL.SAPR*ODL.IVQT*LE.ARAT end as [Sales Amt]\n,          CASE WHEN LE.CUAM = 0 then 0 else ODL.IVQT end as [Sales Qty]\n,          CASE WHEN LE.RECO = 9 then 'Paid' else 'Not Paid' end as [Paid Status]\n,          CAST(CAST(NULLIF(LE.REDE,0) as varchar(8)) as date) as [Paid Date]\n,           CASE WHEN MP.STRT = 'KIT' AND ODL.POSX = 0 THEN 0 \n           WHEN LE.CUAM = 0 then 0 ELSE ODL.DCOS END as [Cost Amt]\n,           OH.SMCD as [Responsible]\nFROM\t\t\tM3.FSLEDG LE --26749\nJOIN\t\t\tM3.OINVOH IV ON LE.CINO = IV.EXIN --15784\nJOIN\t\t\tM3.ODHEAD ODH ON ODH.IVNO = IV.IVNO AND LE.CUNO = ODH.CUNO and LE.ACDT = cast(cast(ODH.ACDT as varchar(10)) as date)\nJOIN\t\t\tM3.ODLINE ODL ON ODH.ORNO = ODL.ORNO AND ODH.DLIX = ODL.DLIX\nJOIN\t\t\tM3.OOLINE AS OL ON ODL.ORNO = OL.ORNO AND ODL.PONR = OL.PONR AND ODL.POSX = OL.POSX\nJOIN            M3.OOHEAD OH on ol.ORNO = OH.ORNO\nJOIN\t\t\tM3.OCUSMA AS OC ON ODH.CUNO = OC.CUNO \nJOIN\t\t\tM3.MITMAS AS IM ON ODL.ITNO = IM.ITNO\nLEFT JOIN       M3.MPDHED MP ON IM.ITNO = MP.PRNO AND MP.STRT = 'KIT'\nWHERE\t\t\tLE.TRCD = 10\nand             ODH.ACDT <> 0\nAND             OC.OREF <> 'TLC INTERCOMPANY'\nAND             ODH.ORNO NOT IN ('1000001170', '1000026212', '5000004149', '1000020120')\nAND             LE.CINO NOT IN ('2400163940', '2999910397', '2999910571', '2400083573', '2400083579', '2400083575', '2400088771'\n                                , '2400088775', '2400088773', '2400088788', '2400102150', '2400081300', '2400068696', '2400060092'\n                                , '2400053326', '2400052745', '2400052544', '2400052542', '2400053348', '2400053347', '2400052543', '2400054060',\n                                '2400054065', '2400053659', '2400060082', '2400060083', '2400054063', '2400054064', '2400053660', '2400058368',\n                                '2400058376', '2400058378', '2400058380', '2400058374', '2400058366', '2400058382', '2400058372', '2400058358',\n                                '2400058362', '2400058364', '2400058356',  '2400058360', '2400058384', '2400058370'\n)\n) A\n\n",
