{
  "name": "CopyPipeline_vhs",
  "properties": {
    "activities": [
      {
        "inputs": [
          {
            "referenceName": "SourceDataset_vhs",
            "type": "DatasetReference"
          }
        ],
        "name": "Copy_vhs",
        "outputs": [
          {
            "referenceName": "DestinationDataset_vhs",
            "type": "DatasetReference"
          }
        ],
        "policy": {
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureInput": false,
          "secureOutput": false,
          "timeout": "7.00:00:00"
        },
        "type": "Copy",
        "typeProperties": {
          "enableStaging": false,
          "sink": {
            "type": "SqlServerSink"
          },
          "source": {
            "partitionOption": "None",
            "type": "SqlServerSource"
          },
          "translator": {
            "mappings": [
              {
                "sink": {
                  "name": "Branch",
                  "physicalType": "varchar",
                  "type": "String"
                },
                "source": {
                  "name": "Branch",
                  "physicalType": "varchar",
                  "type": "String"
                }
              },
              {
                "sink": {
                  "name": "ProductClass",
                  "physicalType": "varchar",
                  "type": "String"
                },
                "source": {
                  "name": "ProductClass",
                  "physicalType": "varchar",
                  "type": "String"
                }
              },
              {
                "sink": {
                  "name": "Brand",
                  "physicalType": "varchar",
                  "type": "String"
                },
                "source": {
                  "name": "Brand",
                  "physicalType": "varchar",
                  "type": "String"
                }
              }
            ],
            "type": "TabularTranslator",
            "typeConversion": true,
            "typeConversionSettings": {
              "allowDataTruncation": true,
              "treatBooleanAsNumber": false
            }
          },
          "validateDataConsistency": false
        },
        "userProperties": [
          {
            "name": "Source",
            "value": "dbo.SalProductClass+"
          },
          {
            "name": "Destination",
            "value": "dbo.SalProductClass+"
          }
        ]
      }
    ]
  }
}
