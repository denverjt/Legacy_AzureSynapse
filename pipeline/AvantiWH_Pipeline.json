{
  "name": "AvantiWH_Pipeline",
  "properties": {
    "activities": [
      {
        "dependsOn": [],
        "name": "ForEach_Table",
        "type": "ForEach",
        "typeProperties": {
          "activities": [
            {
              "dependsOn": [],
              "inputs": [
                {
                  "parameters": {
                    "cw_table": "@item().source.table"
                  },
                  "referenceName": "IN_AvantiWH",
                  "type": "DatasetReference"
                }
              ],
              "name": "Copy_Tables",
              "outputs": [
                {
                  "parameters": {
                    "cw_fileName": "@item().destination.fileName"
                  },
                  "referenceName": "OUT_AvantiWH",
                  "type": "DatasetReference"
                }
              ],
              "policy": {
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureInput": false,
                "secureOutput": false,
                "timeout": "7.00:00:00"
              },
              "type": "Copy",
              "typeProperties": {
                "enableStaging": false,
                "sink": {
                  "formatSettings": {
                    "type": "ParquetWriteSettings"
                  },
                  "storeSettings": {
                    "type": "AzureBlobFSWriteSettings"
                  },
                  "type": "ParquetSink"
                },
                "source": {
                  "partitionOption": "None",
                  "type": "SqlServerSource"
                },
                "validateDataConsistency": false
              },
              "userProperties": [
                {
                  "name": "Source",
                  "value": "dbo.@{item().source.table}"
                },
                {
                  "name": "Destination",
                  "value": "tlclakefs/AvantiWH/@{item().destination.fileName}"
                }
              ]
            }
          ],
          "items": {
            "type": "Expression",
            "value": "@pipeline().parameters.cw_items"
          }
        },
        "userProperties": []
      }
    ],
    "annotations": [],
    "parameters": {
      "cw_items": {
        "defaultValue": [
          {
            "destination": {
              "fileName": "Customer.parquet"
            },
            "source": {
              "table": "Customer"
            }
          },
          {
            "destination": {
              "fileName": "Dim_Scenario.parquet"
            },
            "source": {
              "table": "Dim_Scenario"
            }
          },
          {
            "destination": {
              "fileName": "DimDate.parquet"
            },
            "source": {
              "table": "DimDate"
            }
          },
          {
            "destination": {
              "fileName": "FactSales.parquet"
            },
            "source": {
              "table": "FactSales"
            }
          },
          {
            "destination": {
              "fileName": "GLBalance_Staging.parquet"
            },
            "source": {
              "table": "GLBalance_Staging"
            }
          },
          {
            "destination": {
              "fileName": "Location.parquet"
            },
            "source": {
              "table": "Location"
            }
          },
          {
            "destination": {
              "fileName": "Product.parquet"
            },
            "source": {
              "table": "Product"
            }
          },
          {
            "destination": {
              "fileName": "Supplier.parquet"
            },
            "source": {
              "table": "Supplier"
            }
          }
        ],
        "type": "Array"
      }
    }
  }
}
