{
  "name": "NetsuiteVT_Pipeline",
  "properties": {
    "activities": [
      {
        "dependsOn": [],
        "name": "ForEach_Table",
        "type": "ForEach",
        "typeProperties": {
          "activities": [
            {
              "dependsOn": [],
              "inputs": [
                {
                  "parameters": {
                    "cw_table": "@item().source.table"
                  },
                  "referenceName": "IN_NetsuiteVT",
                  "type": "DatasetReference"
                }
              ],
              "name": "Copy_Tables",
              "outputs": [
                {
                  "parameters": {
                    "cw_fileName": "@item().destination.fileName"
                  },
                  "referenceName": "OUT_NetsuiteVT",
                  "type": "DatasetReference"
                }
              ],
              "policy": {
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureInput": false,
                "secureOutput": false,
                "timeout": "7.00:00:00"
              },
              "type": "Copy",
              "typeProperties": {
                "enableStaging": false,
                "sink": {
                  "formatSettings": {
                    "type": "ParquetWriteSettings"
                  },
                  "storeSettings": {
                    "type": "AzureBlobFSWriteSettings"
                  },
                  "type": "ParquetSink"
                },
                "source": {
                  "partitionOption": "None",
                  "type": "SqlServerSource"
                },
                "validateDataConsistency": false
              },
              "userProperties": []
            }
          ],
          "items": {
            "type": "Expression",
            "value": "@pipeline().parameters.cw_items"
          }
        },
        "userProperties": []
      }
    ],
    "annotations": [],
    "parameters": {
