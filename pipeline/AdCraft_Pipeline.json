{
  "name": "AdCraft_Pipeline",
  "properties": {
    "activities": [
      {
        "dependsOn": [],
        "name": "ForEach_Table",
        "type": "ForEach",
        "typeProperties": {
          "activities": [
            {
              "dependsOn": [],
              "inputs": [
                {
                  "parameters": {
                    "cw_tableName": "@item().source.tableName"
                  },
                  "referenceName": "IN_AdCraftD1",
                  "type": "DatasetReference"
                }
              ],
              "name": "Copy_Tables",
              "outputs": [
                {
                  "parameters": {
                    "cw_fileName": "@item().destination.fileName"
                  },
                  "referenceName": "OUT_AdCraftD1",
                  "type": "DatasetReference"
                }
              ],
              "policy": {
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureInput": false,
                "secureOutput": false,
                "timeout": "7.00:00:00"
              },
              "type": "Copy",
              "typeProperties": {
                "enableStaging": false,
                "sink": {
                  "formatSettings": {
                    "type": "ParquetWriteSettings"
                  },
                  "storeSettings": {
                    "type": "AzureBlobFSWriteSettings"
                  },
                  "type": "ParquetSink"
                },
                "source": {
                  "type": "OdbcSource"
                },
                "validateDataConsistency": false
              },
              "userProperties": [
                {
                  "name": "Source",
                  "value": "@{item().source.tableName}"
                },
                {
                  "name": "Destination",
                  "value": "tlclakefs/AdCraft/@{item().destination.fileName}"
                }
              ]
            }
          ],
          "items": {
            "type": "Expression",
            "value": "@pipeline().parameters.cw_items"
          }
        },
        "userProperties": []
      }
    ],
    "annotations": [],
    "parameters": {
      "cw_items": {
        "defaultValue": [
          {
            "destination": {
              "fileName": "wa_item.parquet"
            },
            "source": {
              "tableName": "\"PUB\".\"wa_item\""
            }
          },
          {
