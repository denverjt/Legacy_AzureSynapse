{
  "name": "tlcdw-WorkspaceDefaultSqlServer",
  "properties": {
    "connectVia": {
      "referenceName": "AutoResolveIntegrationRuntime",
      "type": "IntegrationRuntimeReference"
    },
    "parameters": {
      "DBName": {
        "type": "String"
      }
    },
    "type": "AzureSqlDW",
    "typeProperties": {
      "connectionString": "Data Source=tcp:tlcdw.sql.azuresynapse.net,1433;Initial Catalog=@{linkedService().DBName}"
    }
  }
}
